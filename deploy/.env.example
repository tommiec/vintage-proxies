# .env

TZ=Europe/Brussels

# Address at which the iMac/old browser reaches this proxy host.
# WebOne uses this for internal rewrites (env var PROXY_HOSTNAME).
# IP address or hostname that the old browser uses to reach this proxy host.
# Example: PROXY_HOSTNAME=192.168.1.10
PROXY_HOSTNAME=

# AdGuard Home ports.
# Set ADGUARD_DNS_PORT=53 to use AdGuard as DNS on the G3 (requires host port 53 to be free).
# Default 5353 avoids colliding with any host-level DNS service.
ADGUARD_DNS_PORT=5353
ADGUARD_SETUP_PORT=3000
ADGUARD_WEB_PORT=3001
